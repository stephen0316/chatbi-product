GEMINI_API_KEY=replace_with_server_side_key
GEMINI_MODEL=gemini-2.5-flash

# Container internal port. docker-compose maps host 3001 to container 3000.
PORT=3000

# Keep runtime data inside the mounted Docker volume.
CHATBI_STORAGE_DIR=/app/storage
PYTHON_BIN=/opt/chatbi-venv/bin/python

# Uploaded source files and analysis results are cleaned after 3 days.
SESSION_RETENTION_DAYS=3
TMP_RETENTION_MINUTES=30
